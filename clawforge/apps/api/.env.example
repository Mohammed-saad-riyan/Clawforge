# ClawForge API Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Anthropic (Claude) - Required for code generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Models
CLAUDE_MODEL_ROUTING=claude-3-5-haiku-latest
CLAUDE_MODEL_CODING=claude-sonnet-4-20250514

# Ollama (Local LLM) - Optional, for cost savings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b
USE_LOCAL_LLM=true

# GitHub - Required for repository operations
GITHUB_TOKEN=your_github_token_here
GITHUB_DEFAULT_ORG=

# Database
DATABASE_URL=sqlite+aiosqlite:///./clawforge.db

# ChromaDB (RAG)
CHROMA_PERSIST_DIR=./chroma_db

# Cost Limits
MAX_COST_PER_WORKFLOW=5.0
